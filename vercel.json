{
  "rewrites": [
    {
      "source": "/thebestpeople/:path*",
      "destination": "https://v0-thebestpeople.vercel.app/thebestpeople/:path*"
    },
    {
      "source": "/balticway/:path*",
      "destination": "https://v0-baltic-way-visualization.vercel.app/:path*"
    },
    {
      "source": "/_next/:path*",
      "destination": "https://v0-baltic-way-visualization.vercel.app/_next/:path*"
    },
    {
      "source": "/images/:path*",
      "destination": "https://v0-baltic-way-visualization.vercel.app/images/:path*"
    }
  ]
}
